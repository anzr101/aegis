# ── AEGIS configuration ────────────────────────────────────────────
# Leave this file as-is to run in DEMO mode (no key needed, fully working).
# Add a real Anthropic key to switch the whole pipeline to LIVE AI output.

# Get a key at https://console.anthropic.com  → starts with "sk-ant-..."
ANTHROPIC_API_KEY=

# Optional — model + pacing
AEGIS_MODEL=claude-sonnet-4-6
AEGIS_DEMO_DELAY=0.012
AEGIS_AGENT_PAUSE=0.35

# ── AWS deployment (used only by deploy/aws/deploy.py) ──
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=ap-south-1
