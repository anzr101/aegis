# AEGIS backend — environment configuration

# REQUIRED — your Anthropic API key
ANTHROPIC_API_KEY=sk-ant-...

# Models (defaults: Haiku for the 4 operational agents, Sonnet for synthesis)
OPERATIONAL_MODEL=claude-haiku-4-5
SUPERVISOR_MODEL=claude-sonnet-5

# Database — SQLite for zero-setup dev; Postgres in production:
# DATABASE_URL=postgresql+asyncpg://aegis:aegis@localhost:5432/aegis
DATABASE_URL=sqlite+aiosqlite:///./aegis.db

# Server
HOST=0.0.0.0
PORT=8000
CORS_ORIGINS=http://localhost:3000,http://localhost:3001

# Trend agent live web search (Anthropic server-side tool; small extra cost)
ENABLE_WEB_SEARCH=true
MAX_WEB_SEARCHES=3

# Limits
MAX_TOKENS_PER_AGENT=4096
MAX_TOKENS_SUPERVISOR=16000
MAX_RETRIES=3
MEMORY_TOP_K=5

LOG_LEVEL=INFO
